# Optional. If omitted on the first run, deploy.sh generates a 64-character key.
QWEN36_API_KEY=replace-me
# HF_TOKEN is optional for public downloads, but recommended for rate limits.
HF_TOKEN=hf_replace_me

# Optional overrides
# WORKSPACE=/workspace
# MAIN_MODEL_VARIANT=nvidia  # nvidia or mmangkad
# DFLASH_BLOCK_SIZE=8
# KV_CACHE_DTYPE=bfloat16
# PUBLIC_API_PORT=8000
# PROXY_KEEP_ALIVE_SECONDS=60
# WAIT_TIMEOUT=1800
# SKIP_MODEL_DOWNLOAD=0
# SKIP_PYTHON_INSTALL=0
# SKIP_PUBLIC_PORT_CHECK=0
# ALLOW_NON_B200=0
